<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title }}{% endblock %}</title>
    <meta name="description" content="{{ page_description }}">
    <meta name="robots" content="{{ robots_directive }}">
    <meta name="theme-color" content="{{ theme_color }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" href="{{ site_assets.favicon_ico }}" sizes="32x32">
    <link rel="icon" href="{{ site_assets.icon_svg }}" type="image/svg+xml">
    <link rel="apple-touch-icon" href="{{ site_assets.apple_touch_icon }}">
    <link rel="manifest" href="{{ site_assets.manifest }}">
    <meta property="og:site_name" content="{{ site_name }}">
    <meta property="og:title" content="{{ page_title }}">
    <meta property="og:description" content="{{ page_description }}">
    <meta property="og:type" content="{{ og_type }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:image" content="{{ og_image_url }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title }}">
    <meta name="twitter:description" content="{{ page_description }}">
    <meta name="twitter:image" content="{{ og_image_url }}">
    {% if photoswipe_css_path is defined and photoswipe_css_path %}
    <link rel="stylesheet" href="{{ photoswipe_css_path }}">
    {% endif %}
    <style>
        :root {
            --bg: #f4f8fb;
            --text: #073b4c;
            --muted: #5a7683;
            --border: #cfe0e8;
            --accent: #10789b;
            --accent-hover: #0c6f8f;
            --card-bg: #ffffff;
            --badge-bg: #def7ef;
            --brand-glow: rgba(17, 138, 178, 0.1);
        }
        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #091f29;
                --text: #ebf5f8;
                --muted: #9ec0cb;
                --border: #1d4959;
                --accent: #23a1cb;
                --accent-hover: #79d2ea;
                --card-bg: #10303d;
                --badge-bg: #153d32;
                --brand-glow: rgba(36, 184, 145, 0.16);
            }
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: "Source Sans 3", "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1.5rem;
        }
        nav {
            border-bottom: 1px solid var(--border);
            padding: 0.75rem 0;
            margin-bottom: 1.5rem;
        }
        nav .container {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding-top: 0;
            padding-bottom: 0;
        }
        nav .brand {
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--accent);
            text-decoration: none;
        }
        nav .brand img {
            width: 2.5rem;
            height: 2.5rem;
            padding: 0.2rem;
        }
        a {
            color: var(--accent);
            text-decoration: underline;
        }
        nav a {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.9rem;
        }
        nav a:hover { color: var(--accent-hover); }
        nav a.active { color: var(--text); font-weight: 600; }
        h1 { font-size: 1.75rem; margin-bottom: 0.5rem; }
        h2 { font-size: 1.35rem; margin: 1.5rem 0 0.75rem; }
        h3 { font-size: 1.1rem; margin: 1.25rem 0 0.5rem; }
        p { color: var(--muted); margin-bottom: 1rem; }
        .study-card {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            background: var(--card-bg);
            transition: border-color 0.15s;
        }
        .study-card:hover { border-color: var(--accent); }
        .study-card a {
            text-decoration: none;
            color: var(--text);
            font-weight: 600;
            font-size: 1.1rem;
        }
        .study-card .meta {
            font-size: 0.85rem;
            color: var(--muted);
            margin-top: 0.35rem;
        }
        .figure-section {
            margin: 1.5rem 0;
        }
        .figure-section .plotly-graph-div {
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
        }
        .toc {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.5rem;
        }
        .toc h3 { margin-top: 0; }
        .toc ul { list-style: none; padding: 0; }
        .toc li { margin: 0.35rem 0; }
        .toc a { color: var(--accent); text-decoration: none; font-size: 0.9rem; }
        .toc a:hover { text-decoration: underline; }
        /* Comparison sections */
        .comparison-strategy {
            margin: 1.5rem 0;
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
        }
        .comparison-strategy > summary {
            cursor: pointer;
            padding: 0.75rem 1.25rem;
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            list-style: none;
        }
        .comparison-strategy > summary::-webkit-details-marker { display: none; }
        .comparison-strategy > summary::before {
            content: "▸ ";
            font-size: 0.85rem;
            margin-right: 0.3rem;
            color: var(--muted);
        }
        .comparison-strategy[open] > summary::before { content: "▾ "; }
        .comparison-strategy[open] > summary {
            border-bottom: 1px solid var(--border);
        }
        .comparison-resolution {
            margin: 1rem 1.25rem;
            border: 1px solid var(--border);
            border-radius: 6px;
        }
        .comparison-resolution > summary {
            cursor: pointer;
            padding: 0.5rem 1rem;
            background: var(--card-bg);
        }
        .comparison-resolution > summary::-webkit-details-marker { display: none; }
        .comparison-resolution > summary::before {
            content: "▸ ";
            font-size: 0.8rem;
            margin-right: 0.2rem;
            color: var(--muted);
        }
        .comparison-resolution[open] > summary::before { content: "▾ "; }
        .strategy-description {
            margin: 0.75rem 1.25rem;
            font-size: 0.92rem;
        }
        .comparison-figure {
            margin: 1rem 1.25rem 1.5rem;
        }
        .comparison-figure h4 {
            font-size: 1.05rem;
            margin-bottom: 0.35rem;
        }
        .comparison-figure p {
            font-size: 0.88rem;
            margin-bottom: 0.75rem;
        }
        .comparison-img {
            max-width: 100%;
            height: auto;
            border: 1px solid var(--border);
            border-radius: 6px;
            display: block;
        }
        .comparison-img--lossless {
            image-rendering: pixelated;
            image-rendering: crisp-edges;
        }
        .comparison-grid-item {
            margin-bottom: 1rem;
        }
        .comparison-grid-item:last-child {
            margin-bottom: 0;
        }
        /* Gallery (PhotoSwipe) anchor wrapper */
        .pswp-gallery a[data-pswp-width] {
            display: block;
            cursor: zoom-in;
            text-decoration: none;
        }
        /* Back to top link */
        .back-to-top {
            text-align: right;
            font-size: 0.8rem;
            margin-top: 0.5rem;
            margin-bottom: 0;
        }
        .back-to-top a {
            color: var(--muted);
            text-decoration: none;
        }
        .back-to-top a:hover {
            color: var(--accent);
            text-decoration: underline;
        }
        /* Nested TOC for comparison subchapters */
        .toc ul ul {
            margin-top: 0.2rem;
            padding-left: 1.2rem;
        }
        footer {
            border-top: 1px solid var(--border);
            padding: 1rem 0;
            margin-top: 2rem;
            text-align: center;
            font-size: 0.8rem;
            color: var(--muted);
        }
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body>
    <main>
        <nav>
            <div class="container">
                <a href="{{ index_path }}" class="brand">
                    <img src="{{ site_assets.logo_svg }}" alt="{{ site_name }} logo">
                    <span>{{ site_name }}</span>
                </a>
                {% block nav_links %}{% endblock %}
            </div>
        </nav>
        <div class="container">
            {% block content %}{% endblock %}
        </div>
    </main>
    <footer>
        <div class="container">
            Generated by <a href="{{ repository_url }}">web-image-formats-research</a>
            &middot; {{ generation_timestamp }}
        </div>
    </footer>
</body>
</html>
