{
  "$schema": "../study.schema.json",
  "id": "avif-chroma-subsampling",
  "name": "AVIF Chroma Subsampling",
  "description": "Compare AVIF with 4:4:4 and 4:2:0 chroma subsampling at the same quality levels using the DIV2K validation set.",
  "comparison": {
    "tile_parameter": "chroma_subsampling",
    "targets": [
      { "metric": "ssimulacra2", "values": [65, 70, 75, 80, 85, 90] },
      { "metric": "butteraugli", "values": [2.0, 2.5, 3.0, 3.5] },
      { "metric": "bytes_per_pixel", "values": [0.1, 0.15, 0.2, 0.25, 0.3, 0.35, 0.4, 0.45, 0.5, 0.55, 0.6] }
    ],
    "exclude_images": ["0828.png"]
  },
  "analysis": {
    "x_axis": "quality",
    "group_by": "chroma_subsampling"
  },
  "dataset": {
    "id": "div2k-valid",
    "max_images": 100
  },
  "encoders": [
    {
      "format": "avif",
      "quality": [30, 40, 50, 60, 70, 80, 90],
      "chroma_subsampling": ["444", "420"],
      "speed": 4
    }
  ]
}
