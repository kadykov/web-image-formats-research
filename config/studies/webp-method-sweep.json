{
  "$schema": "../study.schema.json",
  "id": "webp-method-sweep",
  "name": "WebP Method Settings Study",
  "description": "Study how WebP encoding method affects quality and file size. Tests method settings from 0 (fastest) to 6 (slowest/best) at representative quality levels to find the optimal method/quality tradeoff.",
  "comparison": {
    "tile_parameter": "method",
    "targets": [
      { "metric": "ssimulacra2", "values": [65, 70, 75, 80, 85, 90] },
      { "metric": "butteraugli", "values": [2.0, 2.5, 3.0, 3.5] },
      { "metric": "bytes_per_pixel", "values": [0.1, 0.15, 0.2, 0.25, 0.3, 0.35, 0.4, 0.45, 0.5, 0.55, 0.6] }
    ],
    "exclude_images": ["0828.png"]
  },
  "analysis": {
    "x_axis": "method",
    "group_by": "quality"
  },
  "dataset": {
    "id": "div2k-valid",
    "max_images": 100
  },
  "encoders": [
    {
      "format": "webp",
      "quality": [30, 40, 50, 60, 70, 80, 90, 100],
      "method": [0, 1, 2, 3, 4, 5, 6]
    }
  ]
}
